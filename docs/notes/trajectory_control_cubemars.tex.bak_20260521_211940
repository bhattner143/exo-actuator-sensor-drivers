\section{Controllers}
\label{sec:ctrl}
% =========================================================================

All controllers are compared in Table~\ref{tab:summary} at the end of
this section.

% -------------------------------------------------------------------------
\subsection{Joint-space PD}
\label{sec:pd}
% -------------------------------------------------------------------------

\textbf{Idea.}  Ignore robot dynamics; treat each joint independently as
a spring-damper.

\begin{equation}
  \vtau = \Kp\,\ve + \Kd\,\ved,
  \quad \ve = \vq_d - \vq, \quad \ved = \vqd_d - \vqd.
  \label{eq:pd}
\end{equation}

$\Kp=\diag(k_{p1},k_{p2})$ and $\Kd=\diag(k_{d1},k_{d2})$ are diagonal
positive-definite gain matrices.  For stable regulation choose
$k_{pi} > 0$, $k_{di} > 0$.

\paragraph{MIT mode mapping.}
The motor's own on-board PD loop \eqref{eq:mit} \emph{already is} this
controller when $\tau_\mathrm{ff}=0$.  Set the MIT gains directly:

\begin{lstlisting}[caption={Joint-space PD via on-board MIT gains}]
# shoulder = j1, elbow = j2
bus1.write("goal_position", {"j1": q_d1}, kp=60, kd=1.5)
bus2.write("goal_position", {"j2": q_d2}, kp=40, kd=1.2)
\end{lstlisting}

This works but ignores cross-coupling between joints.  Suitable for
low-speed, lightly loaded motions.

% -------------------------------------------------------------------------
\subsection{Joint-space PD with Gravity Compensation}
\label{sec:pdg}
% -------------------------------------------------------------------------

Add the static gravity term to remove steady-state error:

\begin{equation}
  \vtau = \Kp\,\ve + \Kd\,\ved + \vg(\vq).
  \label{eq:pdg}
\end{equation}

In MIT mode, pass the gravity torques as feedforward:

\begin{lstlisting}[caption={PD + gravity compensation}]
import numpy as np

def gravity(q, L, m, g=9.81):
    g1 = g*((m[0]/2 + m[1])*L[0]*np.cos(q[0])
             + m[1]*L[1]/2*np.cos(q[0]+q[1]))
    g2 = g*m[1]*L[1]/2*np.cos(q[0]+q[1])
    return np.array([g1, g2])

# Inside control loop:
q, dq, _ = bus1.read_state()["j1"], ...  # fetch state
tau_g = gravity(q, L, m)

bus1.write("goal_position", {"j1": q_d[0]},
           kp=60, kd=1.5, tau_ff=tau_g[0])
bus2.write("goal_position", {"j2": q_d[1]},
           kp=40, kd=1.2, tau_ff=tau_g[1])
\end{lstlisting}

% -------------------------------------------------------------------------
\subsection{Joint-space PID}
\label{sec:pid}
% -------------------------------------------------------------------------

Add an integral term to eliminate residual steady-state error:

\begin{equation}
  \vtau = \Kp\,\ve + \Ki\int_0^t\!\ve\,d\tau + \Kd\,\ved.
  \label{eq:pid}
\end{equation}

\textbf{Anti-windup:} clamp the integral
$\|\mathbf{e}_I\|_\infty \le e_I^\mathrm{max}$ each tick.
Send the computed torque entirely as $\tau_\mathrm{ff}$ (set $K_p=K_d=0$
in the MIT frame) so on-board gains do not double-count:

\begin{lstlisting}[caption={Software PID (tau\_ff only)}]
e_int = np.zeros(2)   # persistent integral accumulator

def pid_step(q, dq, q_d, dqd, dt, Kp, Ki, Kd, e_int,
             e_int_max=0.5):
    e   = q_d - q
    de  = dqd - dq
    e_int += e * dt
    e_int  = np.clip(e_int, -e_int_max, e_int_max)  # anti-windup
    return Kp*e + Ki*e_int + Kd*de, e_int

# Usage (kp=kd=0: pure tau_ff)
tau, e_int = pid_step(q, dq, q_d, dqd, dt,
                      Kp=np.array([40,30]),
                      Ki=np.array([5, 3]),
                      Kd=np.array([1.5,1.0]), e_int=e_int)
bus1.write("goal_torque", {"j1": tau[0]})
bus2.write("goal_torque", {"j2": tau[1]})
\end{lstlisting}

% -------------------------------------------------------------------------
\subsection{Computed Torque Control (CTC)}
\label{sec:ctc}
% -------------------------------------------------------------------------

\textbf{Idea.}  Invert the full nonlinear dynamics so the closed-loop
error behaves as a \emph{linear} second-order system:

\begin{equation}
  \boxed{
    \vtau = \M(\vq)\bigl[\vqdd_d + \Kd\,\ved + \Kp\,\ve\bigr]
          + \C(\vq,\vqd)\,\vqd + \vg(\vq).
  }
  \label{eq:ctc}
\end{equation}

Substituting into \eqref{eq:eom} gives the linear error dynamics:
\begin{equation}
  \vqdd_e + \Kd\,\vqd_e + \Kp\,\vq_e = \mathbf{0},
  \label{eq:ctc_err}
\end{equation}
where $\vq_e=\vq_d-\vq$.  Choose $\Kd=2\zeta\omega_n\mathbf{I}$ and
$\Kp=\omega_n^2\mathbf{I}$ for critically damped response at bandwidth
$\omega_n$ [rad/s].

\paragraph{Practical bandwidth.}  The full CTC loop must close at
$\ge 5\,\omega_n$.  With the CubeMars CAN round-trip $\approx$1\,ms
(1 kHz effective), target $\omega_n\le 20$\,rad/s.

\begin{lstlisting}[caption={Computed Torque Control implementation}]
import numpy as np

# --- Robot parameters (fill in your measured values) ---
L  = np.array([0.30, 0.28])      # link lengths  [m]
m  = np.array([1.80, 1.20])      # link masses   [kg]
g  = 9.81

def inertia_matrix(q):
    c2 = np.cos(q[1])
    M11 = (4/3*m[0]*L[0]**2
           + m[1]*(L[0]**2 + 4/3*L[1]**2 + 2*L[0]*L[1]*c2))
    M12 = m[1]*(4/3*L[1]**2 + L[0]*L[1]*c2)
    M22 = 4/3*m[1]*L[1]**2
    return np.array([[M11, M12], [M12, M22]])

def coriolis_matrix(q, dq):
    h   = -m[1]*L[0]*L[1]*np.sin(q[1])
    return np.array([[h*dq[1],          h*(dq[0]+dq[1])],
                     [-h*dq[0],         0.0            ]])

def gravity_vector(q):
    g1 = g*((m[0]/2+m[1])*L[0]*np.cos(q[0])
             + m[1]*L[1]/2*np.cos(q[0]+q[1]))
    g2 = g*m[1]*L[1]/2*np.cos(q[0]+q[1])
    return np.array([g1, g2])

# --- CTC gains (critically damped, omega_n = 15 rad/s) ---
wn  = 15.0
Kp  = wn**2  * np.eye(2)
Kd  = 2*wn   * np.eye(2)   # zeta = 1

# --- Control loop (100 Hz) ---
def ctc_torque(q, dq, q_d, dqd, qdd_d):
    e   = q_d  - q
    de  = dqd  - dq
    v   = qdd_d + Kd @ de + Kp @ e   # desired acceleration
    tau = inertia_matrix(q) @ v \
        + coriolis_matrix(q, dq) @ dq \
        + gravity_vector(q)
    return np.clip(tau, -12.0, 12.0)  # AK60-6 T_MAX = 12 N.m

# Send as pure feedforward (kp=kd=0 bypasses on-board PD):
tau = ctc_torque(q, dq, q_d, dqd, qdd_d)
bus1.write("goal_torque", {"j1": tau[0]})
bus2.write("goal_torque", {"j2": tau[1]})
\end{lstlisting}

\paragraph{Robustness note.}  CTC performance degrades when the model
parameters ($m_i$, $L_i$) are inaccurate.  Add a PD feedforward term
in the MIT frame as an outer stabilizing loop (Section~\ref{sec:ctc_pd}).

% -------------------------------------------------------------------------
\subsection{CTC with Inner MIT Damping}
\label{sec:ctc_pd}
% -------------------------------------------------------------------------

A practical hybrid: CTC provides the model-inversion feedforward while
small on-board $K_d$ damps unmodelled high-frequency oscillations without
fighting the CTC loop:

\begin{equation}
  \tau_\mathrm{ff} = \M(\vq)\bigl[\vqdd_d + \Kd^\mathrm{outer}\,\ved
                       + \Kp^\mathrm{outer}\,\ve\bigr]
                   + \C\vqd + \vg(\vq),
  \label{eq:ctc_hybrid}
\end{equation}
\begin{equation}
  \text{CAN frame:}\quad K_p^\mathrm{MIT}=0,\quad
  K_d^\mathrm{MIT}=0.3\text{--}0.6,\quad
  \tau_\mathrm{ff}=\text{eq.~\eqref{eq:ctc_hybrid}}.
  \label{eq:ctc_hybrid_can}
\end{equation}

\begin{lstlisting}[caption={Hybrid CTC -- feedforward + small on-board damping}]
tau = ctc_torque(q, dq, q_d, dqd, qdd_d)
# kp=0 (no spring), kd=0.4 (damps encoder noise), tau_ff = CTC output
bus1.write("mit_command", {"j1": q_d[0]},
           kp=0.0, kd=0.4, dq_des=dqd[0], tau_ff=tau[0])
bus2.write("mit_command", {"j2": q_d[1]},
           kp=0.0, kd=0.4, dq_des=dqd[1], tau_ff=tau[1])
\end{lstlisting}

% -------------------------------------------------------------------------
\subsection{Cartesian PD (Jacobian Transpose)}
\label{sec:cart_pd}
% -------------------------------------------------------------------------

Apply spring-damper forces \emph{in Cartesian space} and back-project
through the Jacobian transpose:

\begin{equation}
  \vtau = \J^T(\vq)\bigl[\Kp^\mathrm{cart}(\vp_d-\vp)
              + \Kd^\mathrm{cart}(\vpd_d-\vpd)\bigr] + \vg(\vq).
  \label{eq:cartpd}
\end{equation}

No matrix inversion needed; avoids singularity issues present in
pseudoinverse methods (near singularity the transpose simply produces
less Cartesian force, which is safe).

\begin{lstlisting}[caption={Cartesian PD via Jacobian transpose}]
def jacobian(q):
    s1  = np.sin(q[0]);  c1  = np.cos(q[0])
    s12 = np.sin(q[0]+q[1]); c12 = np.cos(q[0]+q[1])
    return np.array([
        [-L[0]*s1 - L[1]*s12,  -L[1]*s12],
        [ L[0]*c1 + L[1]*c12,   L[1]*c12]
    ])

def fk(q):
    return np.array([
        L[0]*np.cos(q[0]) + L[1]*np.cos(q[0]+q[1]),
        L[0]*np.sin(q[0]) + L[1]*np.sin(q[0]+q[1])
    ])

Kpc = np.diag([200, 200])   # N/m Cartesian stiffness
Kdc = np.diag([ 20,  20])   # N.s/m Cartesian damping

def cartpd_torque(q, dq, p_d, pd_d):
    p   = fk(q)
    J   = jacobian(q)
    pd  = J @ dq                     # current EE velocity
    F   = Kpc @ (p_d - p) + Kdc @ (pd_d - pd)
    return J.T @ F + gravity_vector(q)

tau = cartpd_torque(q, dq, p_d, pd_d)
bus1.write("goal_torque", {"j1": tau[0]})
bus2.write("goal_torque", {"j2": tau[1]})
\end{lstlisting}

% -------------------------------------------------------------------------
\subsection{Operational Space Control (Task-Space Inversion)}
\label{sec:osc}
% -------------------------------------------------------------------------

Full model-based control directly in task space.  Define the
\emph{operational-space inertia matrix}
$\boldsymbol\Lambda = (\J\M^{-1}\J^T)^{-1}$,
Coriolis-like term $\boldsymbol\mu = \boldsymbol\Lambda\J\M^{-1}\C\vqd$,
and gravity projection $\boldsymbol\rho = \boldsymbol\Lambda\J\M^{-1}\vg$:

\begin{equation}
  \vtau = \J^T\!\left[
    \boldsymbol\Lambda\bigl(\vpdd_d + \Kd^\mathrm{OS}\,\ved^\mathrm{cart}
                            + \Kp^\mathrm{OS}\,\ve^\mathrm{cart}\bigr)
    + \boldsymbol\mu + \boldsymbol\rho
  \right],
  \label{eq:osc}
\end{equation}
where $\ve^\mathrm{cart}=\vp_d-\vp$ and $\ved^\mathrm{cart}=\vpd_d-\vpd$.
The closed-loop task-space dynamics are linear: $\vpdd_e + \Kd^\mathrm{OS}\vpd_e + \Kp^\mathrm{OS}\vp_e=\mathbf{0}$.

\begin{lstlisting}[caption={Operational Space Control}]
def osc_torque(q, dq, p_d, pd_d, pdd_d):
    J  = jacobian(q);   M  = inertia_matrix(q)
    C  = coriolis_matrix(q, dq);  gv = gravity_vector(q)
    Minv = np.linalg.inv(M)

    lam_inv = J @ Minv @ J.T
    lam     = np.linalg.inv(lam_inv + 1e-4*np.eye(2))  # damped

    mu  = lam @ J @ Minv @ C @ dq
    rho = lam @ J @ Minv @ gv

    p   = fk(q)
    pd  = J @ dq
    e_c  = p_d  - p
    de_c = pd_d - pd

    Kp_os = 400*np.eye(2)    # N/m
    Kd_os =  40*np.eye(2)    # N.s/m  (critically damped at ~10 Hz)

    F_os  = lam @ (pdd_d + Kd_os @ de_c + Kp_os @ e_c) + mu + rho
    return np.clip(J.T @ F_os, -12.0, 12.0)

tau = osc_torque(q, dq, p_d, pd_d, pdd_d)
bus1.write("goal_torque", {"j1": tau[0]})
bus2.write("goal_torque", {"j2": tau[1]})
\end{lstlisting}

% -------------------------------------------------------------------------
\subsection{Cartesian Impedance Control}
\label{sec:impedance}
% -------------------------------------------------------------------------

Impedance control shapes the \emph{apparent mechanical impedance} of the
end-effector -- useful for compliant interaction with the environment:

\begin{equation}
  \boldsymbol{\mathcal{M}}_d\,\ve^\mathrm{cart}_{dd}
  + \mathbf{B}_d\,\ved^\mathrm{cart}
  + \mathbf{K}_d\,\ve^\mathrm{cart} = \mathbf{f}_\mathrm{ext},
  \label{eq:impedance}
\end{equation}

where $\boldsymbol{\mathcal{M}}_d$, $\mathbf{B}_d$, $\mathbf{K}_d$ are the
desired Cartesian inertia, damping, and stiffness tensors and
$\mathbf{f}_\mathrm{ext}$ is the external contact force.
Setting $\mathbf{f}_\mathrm{ext}=\mathbf{0}$ (no contact) reduces to the
trajectory-tracking case.

Implementation via task-space torque:
\begin{equation}
  \vtau = \J^T\bigl[
    \mathbf{K}_d(\vp_d-\vp)
    + \mathbf{B}_d(\vpd_d-\vpd)
    + \boldsymbol{\mathcal{M}}_d(\vpdd_d - \J\M^{-1}(\C\vqd+\vg-\vtau_\mathrm{null}))
  \bigr] + \vg(\vq),
  \label{eq:impedance_impl}
\end{equation}

For free-space tracking the simplified form is equivalent to
Cartesian PD \eqref{eq:cartpd} with $\Kp^\mathrm{cart}\to\mathbf{K}_d$
and $\Kd^\mathrm{cart}\to\mathbf{B}_d$.

\begin{lstlisting}[caption={Cartesian impedance (free-space tracking)}]
# Desired impedance parameters
Md = np.diag([1.0, 1.0])    # kg  -- virtual mass
Bd = np.diag([30,  30 ])    # N.s/m -- virtual damping
Kd = np.diag([300, 300])    # N/m  -- virtual stiffness

def impedance_torque(q, dq, p_d, pd_d, pdd_d):
    J  = jacobian(q)
    p  = fk(q);  pd = J @ dq
    e  = p_d - p;  de = pd_d - pd

    F_imp = Kd @ e + Bd @ de + Md @ pdd_d   # desired task force
    return np.clip(J.T @ F_imp + gravity_vector(q), -12.0, 12.0)

tau = impedance_torque(q, dq, p_d, pd_d, pdd_d)
bus1.write("goal_torque", {"j1": tau[0]})
bus2.write("goal_torque", {"j2": tau[1]})
\end{lstlisting}

The MIT mode can also implement joint-space impedance natively by setting
$K_p^\mathrm{MIT}$ and $K_d^\mathrm{MIT}$ to low values and updating
$q_d$ each tick, as in the kinesthetic teaching scripts
\texttt{08\_kinesthetic\_record.py} / \texttt{05\_kinesthetic\_record.py}.

