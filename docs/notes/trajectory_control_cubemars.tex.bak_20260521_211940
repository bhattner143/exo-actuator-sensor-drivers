% =========================================================================
\section{Robot Model}
\label{sec:model}
% =========================================================================

\subsection{Forward kinematics}

Let $s_1=\sin q_1$, $c_1=\cos q_1$, $s_{12}=\sin(q_1+q_2)$,
$c_{12}=\cos(q_1+q_2)$.  The end-effector Cartesian position is

\begin{equation}
  \vp(\vq) = \begin{bmatrix} x \\ y \end{bmatrix}
           = \begin{bmatrix}
               L_1 c_1 + L_2 c_{12} \\
               L_1 s_1 + L_2 s_{12}
             \end{bmatrix}.
  \label{eq:fk}
\end{equation}

\subsection{Jacobian}

The geometric Jacobian relates joint velocities to end-effector velocity:
$\vpd = \J(\vq)\,\vqd$,

\begin{equation}
  \J(\vq) = \begin{bmatrix}
    -L_1 s_1 - L_2 s_{12} & -L_2 s_{12} \\
     L_1 c_1 + L_2 c_{12} &  L_2 c_{12}
  \end{bmatrix}.
  \label{eq:jac}
\end{equation}

The Jacobian is singular when links are fully extended ($q_2 = 0$ or $\pi$).
Damped pseudoinverse $\J^\dagger = \J^T(\J\J^T + \lambda^2\mathbf{I})^{-1}$
is used near singularities ($\lambda \approx 0.01$--$0.05$).

\subsection{Equations of motion}

The standard rigid-body equations of motion are

\begin{equation}
  \M(\vq)\,\vqdd + \C(\vq,\vqd)\,\vqd + \vg(\vq) = \vtau,
  \label{eq:eom}
\end{equation}

where $\vtau=[\tau_1,\tau_2]^T$ are joint torques delivered by the
motors (output-shaft, N$\cdot$m).

\paragraph{Inertia matrix.}  Treating each link as a uniform rod of mass
$m_i$ and length $L_i$ (so $I_i = m_i L_i^2/3$), with $c_2=\cos q_2$:

\begin{equation}
  \M(\vq) = \begin{bmatrix} M_{11} & M_{12} \\ M_{12} & M_{22} \end{bmatrix},
  \quad
  \begin{aligned}
    M_{11} &= \tfrac{4}{3}m_1 L_1^2 + m_2\bigl(L_1^2 + \tfrac{4}{3}L_2^2
                + 2 L_1 L_2 c_2\bigr),\\
    M_{12} &= m_2\bigl(\tfrac{4}{3}L_2^2 + L_1 L_2 c_2\bigr),\\
    M_{22} &= \tfrac{4}{3}m_2 L_2^2.
  \end{aligned}
  \label{eq:M}
\end{equation}

\paragraph{Coriolis/centrifugal matrix.} With $s_2=\sin q_2$ and
$h = -m_2 L_1 L_2 s_2$:

\begin{equation}
  \C(\vq,\vqd) = \begin{bmatrix}
    h\dot q_2 & h(\dot q_1 + \dot q_2) \\
   -h\dot q_1 & 0
  \end{bmatrix}.
  \label{eq:C}
\end{equation}

\paragraph{Gravity vector.}  (Vertical plane, $Y$ upward.)

\begin{equation}
  \vg(\vq) = g\begin{bmatrix}
    (m_1/2 + m_2)\,L_1 c_1 + m_2 L_2/2\, c_{12} \\
    m_2 L_2/2\, c_{12}
  \end{bmatrix}.
  \label{eq:grav}
\end{equation}

