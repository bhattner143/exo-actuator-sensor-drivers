% =========================================================================
\section{Worked Example: Circle Trajectory with CTC}
\label{sec:example}
% =========================================================================

Generate a circular end-effector trajectory of radius $r=0.05$\,m centred
at $(0.40,\, 0.15)$\,m, period $T=4$\,s, then control it with CTC.

\begin{lstlisting}[caption={Circular trajectory + CTC end-to-end}]
import numpy as np, time
from ak_v3_bus import AkV3Bench

# ---- Arm parameters ----
L = np.array([0.30, 0.28])
m = np.array([1.80, 1.20])
p_c = np.array([0.40, 0.15])   # circle centre
r, T_circ = 0.05, 4.0

# ---- Trajectory ----
def circle(t):
    th  = 2*np.pi*t / T_circ
    p   = p_c + r*np.array([ np.cos(th),  np.sin(th)])
    pd  =       r*2*np.pi/T_circ*np.array([-np.sin(th), np.cos(th)])
    pdd =      -r*(2*np.pi/T_circ)**2*np.array([np.cos(th), np.sin(th)])
    return p, pd, pdd

# ---- IK ----
def ik(p):
    D  = (p@p - L[0]**2 - L[1]**2) / (2*L[0]*L[1])
    D  = np.clip(D, -1+1e-6, 1-1e-6)
    q2 = np.arctan2(np.sqrt(1-D**2), D)    # elbow-up
    q1 = np.arctan2(p[1],p[0]) - np.arctan2(L[1]*np.sin(q2),
                                              L[0]+L[1]*np.cos(q2))
    return np.array([q1, q2])

def jacobian(q):
    s12 = np.sin(q[0]+q[1]); c12 = np.cos(q[0]+q[1])
    s1  = np.sin(q[0]);       c1  = np.cos(q[0])
    return np.array([[-L[0]*s1-L[1]*s12, -L[1]*s12],
                     [ L[0]*c1+L[1]*c12,  L[1]*c12]])

def traj_joint(t):
    p, pd, pdd = circle(t)
    q_d  = ik(p)
    J    = jacobian(q_d)
    Jinv = np.linalg.pinv(J)
    qd   = Jinv @ pd
    qdd  = Jinv @ pdd        # approximate (ignores dJ term at low speed)
    return q_d, qd, qdd

# ---- CTC (from Section 4.4) -- inlined ----
wn = 12.0
Kp_c = wn**2 * np.eye(2)
Kd_c = 2*wn  * np.eye(2)

def M(q):
    c2 = np.cos(q[1])
    m11 = 4/3*m[0]*L[0]**2 + m[1]*(L[0]**2+4/3*L[1]**2+2*L[0]*L[1]*c2)
    m12 = m[1]*(4/3*L[1]**2+L[0]*L[1]*c2)
    return np.array([[m11,m12],[m12,4/3*m[1]*L[1]**2]])

def C(q,dq):
    h = -m[1]*L[0]*L[1]*np.sin(q[1])
    return np.array([[h*dq[1], h*(dq[0]+dq[1])],[-h*dq[0],0.0]])

def gv(q):
    g1 = 9.81*((m[0]/2+m[1])*L[0]*np.cos(q[0])+m[1]*L[1]/2*np.cos(q[0]+q[1]))
    return np.array([g1, 9.81*m[1]*L[1]/2*np.cos(q[0]+q[1])])

def ctc(q, dq, q_d, dqd, qdd_d):
    e  = q_d-q; de = dqd-dq
    v  = qdd_d + Kd_c@de + Kp_c@e
    return np.clip(M(q)@v + C(q,dq)@dq + gv(q), -12.0, 12.0)

# ---- Main loop ----
shoulder = AkV3Bench(can_id=0x01, name="shoulder")
elbow    = AkV3Bench(can_id=0x02, name="elbow")

with shoulder, elbow:
    t0 = time.monotonic()
    while True:
        t  = time.monotonic()-t0
        q1,dq1,_ = shoulder.read_state()["shoulder"]
        q2,dq2,_ = elbow.read_state()["elbow"]
        q  = np.array([q1,q2]); dq = np.array([dq1,dq2])
        q_d, dqd, qdd_d = traj_joint(t)
        tau = ctc(q, dq, q_d, dqd, qdd_d)
        shoulder.write("goal_torque", {"shoulder": tau[0]})
        elbow.write(   "goal_torque", {"elbow":    tau[1]})
        time.sleep(0.01)
\end{lstlisting}

% =========================================================================
\section{Safety Constraints}
\label{sec:safety}
% =========================================================================

\begin{itemize}
  \item \textbf{Torque limits:}  $|\tau_i|\le 12$\,N$\cdot$m (\texttt{T\_MAX}).
        Always clip computed torques before sending.
  \item \textbf{Velocity limits:}  $|\dot q_i|\le 60$\,rad/s.
        Saturate $\dot q_d$ in the trajectory generator.
  \item \textbf{Singularity avoidance:}  $|q_2| > 5^\circ$ from
        fully extended / folded.  Monitor $|\det\J|$; switch to
        Cartesian PD (J-transpose) near singularities.
  \item \textbf{Workspace limits:}  Impose joint-angle limits in IK:
        $q_1\in[-\pi/2,\pi]$, $q_2\in[10^\circ,170^\circ]$ (hardware stops).
  \item \textbf{Emergency stop:}  Send
        \texttt{bus.write("goal\_torque", \{name: 0.0\})} on Ctrl+C
        (handled by \texttt{\_\_exit\_\_} in \texttt{AkV3Bench}).
  \item \textbf{Thermal:}  Monitor \texttt{read\_raw()["shoulder"][3]}
        (MOS temperature); pause if $>70^\circ$C.
\end{itemize}

